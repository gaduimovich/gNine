{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "macos-base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "cacheVariables": {
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
      }
    },
    {
      "name": "macos-arm64",
      "inherits": "macos-base",
      "binaryDir": "${sourceDir}/build-arm64",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_SYSTEM_PROCESSOR": "arm64",
        "GNINE_ENABLE_SDL_PREVIEW": "ON",
        "OMR_TOOLS_IMPORTFILE": "${sourceDir}/build-x86_64/libs/omr/tools/ImportTools.cmake"
      }
    },
    {
      "name": "macos-x86_64",
      "inherits": "macos-base",
      "binaryDir": "${sourceDir}/build-x86_64",
      "environment": {
        "PKG_CONFIG_PATH": "/usr/local/lib/pkgconfig"
      },
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "x86_64",
        "CMAKE_SYSTEM_PROCESSOR": "x86_64",
        "GNINE_ENABLE_SDL_PREVIEW": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-x86_64-tools",
      "configurePreset": "macos-x86_64",
      "targets": [
        "tracegen",
        "tracemerge",
        "hookgen"
      ]
    },
    {
      "name": "build-arm64-gnine",
      "configurePreset": "macos-arm64",
      "targets": [
        "gnine"
      ]
    },
    {
      "name": "build-x86_64-gnine",
      "configurePreset": "macos-x86_64",
      "targets": [
        "gnine"
      ]
    }
  ]
}
