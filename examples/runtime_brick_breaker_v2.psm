             (<= (abs (- shown-x next-paddle-x)) (+ paddle-half-w ball-half))
             (<= (abs (- shown-y paddle-y)) (+ paddle-half-h ball-half))))

      (define after-paddle-vx
        (if paddle-hit
          (clamp (+ wall-vx (/ (- shown-x next-paddle-x) 8)) -3 3)
          wall-vx))

      (define after-paddle-vy
        (if paddle-hit
          (- (abs wall-vy))
          wall-vy))

      (define after-paddle-y
        (if paddle-hit
          77
          shown-y))

      (define hit-b00
        (and (> b00 0)
