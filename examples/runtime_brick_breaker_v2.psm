(()
  (define W 160)
  (define H 90)

  (define paddle-y 82)
  (define paddle-half-w 13)
  (define paddle-half-h 2)
  (define paddle-speed 3)

  (define ball-half 2)

  (define brick-half-w 12)
  (define brick-half-h 3)

  (iterate-until 100
    (()
      (tuple
        (canvas 160 90 3
          (clamp
            (max
              (if (== c 0) 0.03
                (if (== c 1) 0.05 0.10))

              (* (draw-rect 14 18 brick-half-w brick-half-h 1.0)
