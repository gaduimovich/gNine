; Branch-light procedural canvas fill.
; Good for measuring base canvas loop overhead and raw per-pixel math.
;
; Render with:
;   ./gnine --runtime canvas_bench_gradient_4k.psm canvas_bench_gradient_4k.png

(()
  (define W 3840)
  (define H 2160)
  (canvas W H 3
    (clamp
      (+ (* 0.55 (/ j W))
         (* 0.35 (/ i H))
         (* 0.10 (/ c 2)))
      0 1)))
